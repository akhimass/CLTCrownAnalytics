# Copy to .env and fill in values

# Scraping behavior
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=3.5
USER_AGENT="CrownAnalytics/1.0 (academic attendance research; contact: your@email.com)"

# Output format: csv or parquet
EXPORT_FORMAT=csv

# Optional — SeatGeek public API (free tier) for FC/Knights demand baselines
# https://seatgeek.com/api
SEATGEEK_CLIENT_ID=
